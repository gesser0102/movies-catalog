# Read Access Token da TMDB. SEM o prefixo VITE_ de propósito: a variável é
# lida só pelo proxy (vite.config.ts em dev, nginx em produção) e nunca entra
# no bundle do navegador.
TMDB_ACCESS_TOKEN="cole_seu_read_access_token_aqui"

# Base da API vista pelo app. O caminho relativo aponta pro proxy local.
VITE_TMDB_API_BASE_URL="/api/tmdb"

# Base das imagens (posters, backdrops). O tamanho é anexado no código.
VITE_TMDB_IMAGE_BASE_URL="https://image.tmdb.org/t/p"
